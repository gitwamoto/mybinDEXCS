    def setParamsFromDictFiles(self, meshDict_path, setFieldsDict_path, topoSetDict_path):
        meshDict = dictParse.DictParser2(file_name = meshDict_path)
        if meshDict.find_element([{'type': 'block', 'key': 'FoamFile'},
            {'type': 'dictionary', 'key': 'object'},
            {'type': 'word', 'value': 'snappyHexMeshDict'}])['element'] is None:
            raise Exception(f'{eshDict_path} is not a snappyHexMeshDict file.')

        maxCellSize = meshDict.find_element([{'type': 'block', 'key': 'CUSTOM_OPTIONS'},
                {'type': 'dictionary', 'key': 'maxCellSize'}, {'type': 'float|integer'}])['element']
        if maxCellSize is not None:
            self.maxCellSizeCRL.setText(maxCellSize['value'])

        castellatedMeshControls = meshDict.find_element(
            [{'type': 'block', 'key': 'castellatedMeshControls'}])['element']
        featureLevel = dictParse.find_element(
            [{'type': 'dictionary', 'key': 'features'}, {'type': 'list'}, {'type': 'block'},
            {'type': 'dictionary', 'key': 'level'}, {'type': 'integer'}],
            parent = castellatedMeshControls)['element']
        if featureLevel is not None:
            self.featuresLevelCRL.setText(featureLevel['value'])
        featureAngle = dictParse.find_element(
            [{'type': 'dictionary', 'key': 'resolveFeatureAngle'}, {'type': 'float|integer'}],
            parent = castellatedMeshControls)['element']
        if featureAngle is not None:
           self.featureAngleCRL.setText(featureAngle['value'])

        objects = [i[self.grid.OBJECT_NAME] for i in self.grid.table]
        remainder = objects[:]
        shape_name = None
        searchableBox_list = []
        searchableCylinder_list = []
        searchableSphere_list = []
        triSurface_list = []

        refinementSurfaces = dictParse.find_element([{'type': 'block', 'key': 'refinementSurfaces'}],
            parent = castellatedMeshControls)['element']
        for block in meshDict.find_all_elements([{'type': 'block', 'key': 'geometry'}, {'type': 'block'}]):
            block = block['element']
            if block['key'].endswith('.stl'):
                name = dictParse.find_element([{'type': 'dictionary', 'key': 'name'}, {'type': 'word'}],
                    parent = block)['element']['value']
                if dictParse.find_element([{'type': 'block', 'key': name}],
                    parent = refinementSurfaces)['element'] is not None:
                    shape_name = name
                else:
                    triSurface_list.append(name)
            else:
                geometry_type = dictParse.find_element([{'type': 'dictionary', 'key': 'type'}, {'type': 'word'}],
                    parent = block)['element']['value']
                if geometry_type in ('searchableBox', 'searchableRotatedBox'):
                    searchableBox_list.append(block['key'])
                elif geometry_type == 'searchableCylinder':
                    searchableCylinder_list.append(block['key'])
                elif geometry_type == 'searchableSphere':
                    searchableSphere_list.append(block['key'])

        for block in dictParse.find_all_elements([{'type': 'block', 'key': shape_name}, 
            {'type': 'block', 'key': 'regions'}, {'type': 'block'}], parent = refinementSurfaces):
            block = block['element']
            if block['key'] in objects:
                i = objects.index(block['key'])
                remainder.remove(block['key'])
                level = dictParse.find_element([{'type': 'dictionary', 'key': 'level'}, {'type': 'list'},
                    {'type': 'integer'}], parent = block)['element']
                if level is not None:
                    self.grid.setCellValue(i, self.grid.LEVEL, level['value'])
                patchInfo = dictParse.find_element([{'type': 'dictionary', 'key': 'patchInfo'}, {'type': 'block'},
                    {'type': 'dictionary', 'key': 'type'}, {'type': 'word'}], parent = block)['element']
                if patchInfo is not None:
                    self.grid.setCellValue(i, self.grid.TYPE, patchInfo['value'])

        refinements_list = searchableBox_list + searchableCylinder_list + searchableSphere_list + triSurface_list
        for block in dictParse.find_all_elements([{'type': 'block', 'key': 'refinementRegions'},
            {'type': 'block'}], parent = castellatedMeshControls):
            block = block['element']
            if block['key'] in objects and block['key'] in refinements_list:
                i = objects.index(block['key'])
                remainder.remove(block['key'])
                if block['key'] in searchableBox_list:
                    self.grid.setCellValue(i, self.grid.TYPE, 'BoxRefine')
                elif block['key'] in searchableCylinder_list:
                    self.grid.setCellValue(i, self.grid.TYPE, 'CylinderRefine')
                elif block['key'] in searchableSphere_list:
                    self.grid.setCellValue(i, self.grid.TYPE, 'SphereRefine')
                else:
                    self.grid.setCellValue(i, self.grid.TYPE, 'SurfaceRefine')
                levels = dictParse.find_element([{'type': 'dictionary', 'key': 'levels'},
                    {'type', 'list'}, {'type', 'list'}], parent = block)['element']
                if levels is None:
                    continue
                level = dictParse.find_element([{'type': 'integer'}], parent = levels, reverse = True)['element']
                if level is not None:
                    self.grid.setCellValue(i, self.grid.LEVEL, level['value'])
                if block['key'] in triSurface_list:
                    distance = dictParse.find_element([{'type': 'float|integer'}],
                        parent = levels, reverse = True)['element']
                    if distance is not None:
                        self.grid.setCellValue(i, self.grid.RATIO, distance['value'])

        shape_prefix = f'{shape_name}_'
        for block in meshDict.find_all_elements([{'type': 'block', 'key': 'addLayersControls'},
            {'type': 'block', 'key': 'layers'}, {'type': 'block'}]):
            block = block['element']
            if block['key'].startswith(shape_prefix) and block['key'][len(shape_prefix):] in objects:
                i = objects.index(block['key'][len(shape_prefix):])
                nSurfaceLayers = dictParse.find_element([{'type': 'dictionary', 'key': 'nSurfaceLayers'},
                    {'type': 'integer'}], parent = block)['element']
                if nSurfaceLayers is not None:
                    self.grid.setCellValue(i, self.grid.N_LAYERS, nSurfaceLayers['value'])
                    self.grid.setCellValue(i, self.grid.BOUNDARY_LAYER, True)
                expansionRatio = dictParse.find_element([{'type': 'dictionary', 'key': 'expansionRatio'},
                    {'type': 'float|integer'}], parent = block)['element']
                if expansionRatio is not None:
                    self.grid.setCellValue(i, self.grid.RATIO, expansionRatio['value'])

        QtGui.QMessageBox.warning(None, 'LocationInMesh',
            'Confirm that LocationInMesh is selected correctly!', QtGui.QMessageBox.Close)

        if os.path.isfile(setFieldsDict_path):
            setFieldsDict = dictParse.DictParser2(file_name = setFieldsDict_path)
            if setFieldsDict.find_element([{'type': 'block', 'key': 'FoamFile'},
                {'type': 'dictionary', 'key': 'object'},
                {'type': 'word', 'value': 'setFieldsDict'}])['element'] is None:
                raise Exception(f'{setFieldsDict_path} is not a setFieldsDict file.')
        else:
            setFieldsDict = None

        for block in setFieldsDict.find_all_elements([{'type': 'dictionary', 'key': 'regions'},
            {'type': 'list'}, {'type': 'block'}]):
            block = block['element']
            comment = dictParse.find_element([{'type': 'line_comment|block_comment'}],
                parent = block)['element']['value']
            if 'freecad' in comment.lower():
                for i, object in enumerate(objects):
                    if object not in comment:
                        continue
                    remainder.remove(object)
                    if block['key'] == 'boxToCell':
                        self.grid.setCellValue(i, self.grid.TYPE, 'BoxSet')
                    elif block['key'] == 'cylinderToCell':
                        self.grid.setCellValue(i, self.grid.TYPE, 'CylinderSet')
                    else:
                        self.grid.setCellValue(i, self.grid.TYPE, 'SphereSet')

        if os.path.isfile(topoSetDict_path):
            topoSetDict = dictParse.DictParser2(file_name = topoSetDict_path)
            if topoSetDict.find_element([{'type': 'block', 'key': 'FoamFile'},
                {'type': 'dictionary', 'key': 'object'},
                {'type': 'word', 'value': 'topoSetDict'}])['element'] is None:
                raise Exception(f'{topoSetDict_path} is not a topoSetDict file.')
        else:
            topoSetDict = None

        for block in topoSetDict.find_all_elements([{'type': 'dictionary', 'key': 'actions'},
            {'type': 'list'}, {'type': 'block'}]):
            block = block['element']
            setName = dictParse.find_element([{'type': 'dictionary', 'key': 'name'}, {'type': 'word'}],
                parent = block)['element']['value'].replace('CellSet', '').replace()
            if setName not in objects:
                continue
            if dictParse.find_element([{'type': 'dictionary', 'key': 'source'}, {'type': 'word'}],
                parent = block)['element']['value'] != 'rotatedBoxToCell':
                continue
            remainder.remove(setName)
            self.grid.setCellValue(objects.index(setName), self.grid.TYPE, 'BoxTopo')

        for i in remainder:
            self.grid.setCellValue(objects.index(i), self.grid.TYPE, 'LocationInMesh')

        return meshDict, setFieldsDict, topoSetDict

    def actionOnExitButton(self):
        self.close()

class MyController:
    FEATURE_ANGLE = 30
    BASHRC_PATH_4_OPENFOAM = os.path.join(os.sep, 'opt', 'OpenFOAM', 'OpenFOAM-v1906', 'etc', 'bashrc')
    if not os.path.exists(BASHRC_PATH_4_OPENFOAM):
        BASHRC_PATH_4_OPENFOAM = os.path.join(os.sep, 'usr', 'lib', 'openfoam', 'openfoam2106', 'etc', 'bashrc')
    SOLVER_PATH_TEMPLATE = os.path.join(os.sep, 'opt', 'DEXCS', 'template', 'dexcs')

    def __init__(self):
        import FreeCAD
        import Part
        self.doc = App.ActiveDocument
        self.model = MyModel()
        self.meshDict = None
        self.setFieldsDict = None
        self.topoSetDict = None
        starts_with_number = False
        if self.doc.FileName == '':
            QtGui.QMessageBox.critical(None, 'Error',
                'This document has never been saved. Save the document and retry.', QtGui.QMessageBox.Close)
            return
        for obj in self.doc.Objects:
            if obj.ViewObject.Visibility and hasattr(obj, 'Shape'):
                obj.Label = obj.Label.strip()
                l = obj.Label
                obj.Label = re.sub('^([0-9])', r'_\1', l.replace(' ', '_'))
                if obj.Label != l:
                    QtGui.QMessageBox.warning(None, 'Prohibited object label',
                        f'Label fixed: {l} -> {obj.Label}', QtGui.QMessageBox.Close)
        self.MeshFrame = MeshFrame(controller = self,
            freecad_objects = self.doc.Objects,
            case_dir_path = os.path.dirname(self.doc.FileName),
            max_cell_size = self.model.sumOfThreeEdgesOfCadObjects(self.doc.Objects)/60.0,
            features_level = 1,
            feature_angle = MyController.FEATURE_ANGLE)
        self.MeshFrame.show()

    def actionOnCaseButton(self):
        dir_name = QtGui.QFileDialog.getExistingDirectory(self.MeshFrame, 'Choose a directory.',
            os.path.expanduser(os.path.join('~', 'Desktop')))
        if dir_name != '':
            self.MeshFrame.caseDirST.setText(dir_name)

    def actionOnOpenButton(self):
        case_dir_path = self.MeshFrame.caseDirST.text()
        if os.path.isdir(case_dir_path):
            os.system("xdg-open '" + case_dir_path + "'")

    def actionOnExportButton(self):
        if not os.path.isdir(self.MeshFrame.caseDirST.text()):
            QtGui.QMessageBox.critical(None, 'Error',
                self.MeshFrame.caseDirST.text() + ' is not a directory.', QtGui.QMessageBox.Close)
            return
        num_of_LocationInMesh = 0
        for i in self.MeshFrame.grid.table:
            if i[self.MeshFrame.grid.TYPE] == 'LocationInMesh':
                num_of_LocationInMesh += 1
                break
        if num_of_LocationInMesh == 0:
            QtGui.QMessageBox.critical(None, 'Error', 'LocationInMesh is required!\n'
                'Set LocationInMesh and try again.', QtGui.QMessageBox.Close)
            return
        elif num_of_LocationInMesh > 1 and QtGui.QMessageBox.warning(None, 'Multiple LocationInMesh',
            '{} LocationInMesh exist. Is this correct?'.format(num_of_LocationInMesh),
            QtGui.QMessageBox.Yes, QtGui.QMessageBox.No) == QtGui.QMessageBox.No:
            return # chtMultiRegionFoam（共役熱伝導解析）ではLocationInMeshが複数ある
        case_dir_path = self.MeshFrame.caseDirST.text()
        # (DEXCS2019を参考に) OpenFOAMのケースフォルダでない場合の処理を追加（2019/9/6）
        if not os.path.isdir(os.path.join(case_dir_path, 'constant')):
            os.system('rsync -a ' + os.path.join(MyController.SOLVER_PATH_TEMPLATE, 'constant') + ' ' +
                case_dir_path + ' --exclude polyMesh')
        if not os.path.isdir(os.path.join(case_dir_path, 'system')):
            os.system('cp -r ' + os.path.join(MyController.SOLVER_PATH_TEMPLATE, 'system') + ' ' + case_dir_path)
        if not os.path.isdir(os.path.join(case_dir_path, '0')):
            os.system('cp -r ' + os.path.join(MyController.SOLVER_PATH_TEMPLATE, '0') + ' ' + case_dir_path)
        triSurface = os.path.join(case_dir_path, 'constant', 'triSurface')
        if os.path.isdir(triSurface):
            shutil.rmtree(triSurface)
        elif os.path.isfile(triSurface):
            os.remove(triSurface)
        os.mkdir(triSurface)
        extendedFeatureEdgeMesh = os.path.join(case_dir_path, 'constant', 'extendedFeatureEdgeMesh')
        if os.path.isdir(extendedFeatureEdgeMesh):
            shutil.rmtree(extendedFeatureEdgeMesh)
        elif os.path.isfile(extendedFeatureEdgeMesh):
            os.remove(extendedFeatureEdgeMesh)
        stl_file_name = os.path.join(triSurface, re.sub('^([0-9])', r'_\1', os.path.basename(case_dir_path)) + '.stl')
        box = self.model.exportStl(self.doc.Objects, self.MeshFrame.grid, stl_file_name)
        self.model.makeSurfaceFeatureExtractDict(case_dir_path = case_dir_path,
            surface_file_name = stl_file_name, feature_angle = self.MeshFrame.featureAngleCRL.text())
        cwd = os.getcwd()
        os.chdir(case_dir_path)
        command = '. ' + MyController.BASHRC_PATH_4_OPENFOAM + ' && ' + 'surfaceFeatureExtract'
        if os.system(command) != 0:
            QtGui.QMessageBox.critical(None, 'Error', command + ' was not succeed.', QtGui.QMessageBox.Close)
            os.chdir(cwd)
            return
        os.chdir(cwd)
        self.model.makeMeshDict(case_dir_path = case_dir_path,
            surface_file_name = stl_file_name,
            max_cell_size = self.MeshFrame.maxCellSizeCRL.text(),
            bounding_box = box,
            freecad_objects = self.doc.Objects,
            grid = self.MeshFrame.grid,
            features_level = self.MeshFrame.featuresLevelCRL.text(),
            feature_angle = self.MeshFrame.featureAngleCRL.text(),
            meshDict = self.meshDict)
        self.model.makeSetFieldsDict(case_dir_path = case_dir_path,
            freecad_objects = self.doc.Objects,
            grid = self.MeshFrame.grid,
            setFieldsDict = self.setFieldsDict)
        self.model.makeTopoSetDict(case_dir_path = case_dir_path,
            freecad_objects = self.doc.Objects,
            grid = self.MeshFrame.grid,
            topoSetDict = self.topoSetDict)
        QtGui.QMessageBox.information(None, 'Done',
            'File system/snappyHexMeshDict for snappyHexMesh has been created.', QtGui.QMessageBox.Close)

    def actionOnSHMeshButton(self):
        case_dir_path = self.MeshFrame.caseDirST.text()
        if not os.path.isfile(os.path.join(case_dir_path, 'system', 'snappyHexMeshDict')):
            QtGui.QMessageBox.critical(None, 'No snappyHexMeshDict',
                "File system/snappyHexMeshDict doesn't exist.", QtGui.QMessageBox.Close)
            return
        if QtGui.QMessageBox.question(None, 'snappyHexMesh',
            'Really exicute snappyHexMesh?',
            QtGui.QMessageBox.Yes, QtGui.QMessageBox.No) == QtGui.QMessageBox.Yes:
            cwd = os.getcwd()
            os.chdir(case_dir_path)
            os.system('gnome-terminal -- bash -c ' + '". ' + MyController.BASHRC_PATH_4_OPENFOAM + ' && ' +
                os.path.join(binDEXCS_path, 'snappyHexMeshを実行.py') + '; exec bash"') # exec bashで画面が消えなくなる
            os.chdir(cwd)

    def actionOnExtrudeMeshButton(self):
        if QtGui.QMessageBox.question(None, '2D by extrudeMesh',
            'Really exicute extrudeMesh to generate a two-dimensional mesh?',
            QtGui.QMessageBox.Yes, QtGui.QMessageBox.No) == QtGui.QMessageBox.Yes:
            cwd = os.getcwd()
            os.chdir(self.MeshFrame.caseDirST.text())
            os.system('gnome-terminal -- bash -c ' + '". ' + MyController.BASHRC_PATH_4_OPENFOAM + ' && ' +
                os.path.join(binDEXCS_path, '2次元メッシュに.py') + '; exec bash"') # exec bashで画面が消えなくなる
            os.chdir(cwd)

    def actionOnImproveMeshQualityButton(self):
        if QtGui.QMessageBox.question(None, 'improveMeshQuality',
            'Really exicute improveMeshQuality?',
            QtGui.QMessageBox.Yes, QtGui.QMessageBox.No) == QtGui.QMessageBox.Yes:
