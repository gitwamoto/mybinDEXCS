            os.system('gnome-terminal -- bash -c ' + '". ' + MyController.BASHRC_PATH_4_OPENFOAM + ' && ' +
                os.path.join(binDEXCS_path, 'patchを平面に.py') + '; exec bash"') # exec bashで画面が消えなくなる
            os.chdir(cwd)

    def actionOnLoadButton(self):
        case_dir_path = self.MeshFrame.caseDirST.text()
        if not os.path.isdir(case_dir_path):
            return
        try:
            self.meshDict, self.setFieldsDict, self.topoSetDict = self.MeshFrame.setParamsFromDictFiles(
                os.path.join(case_dir_path, 'system', 'snappyHexMeshDict'),
                os.path.join(case_dir_path, 'system', 'setFieldsDict'),
                os.path.join(case_dir_path, 'system', 'topoSetDict'))
        except Exception as e:
            self.meshDict = None
            self.setFieldsDict = None
            self.topoSetDict = None
            QtGui.QMessageBox.critical(None, 'Error', str(e), QtGui.QMessageBox.Close)

    def actionOnEditButton(self):
        meshDict_path = os.path.join(self.MeshFrame.caseDirST.text(), 'system', 'snappyHexMeshDict')
        if not os.path.isfile(meshDict_path):
            QtGui.QMessageBox.critical(None, 'No snappyHexMeshDict',
                "File system/snappyHexMeshDict doesn't exist.", QtGui.QMessageBox.Close)
            return
        if QtGui.QMessageBox.question(None, 'Edit',
            'The file system/snappyHexMeshDict last exported/saved will be edited.\n' +
            'Really edit?', QtGui.QMessageBox.Yes, QtGui.QMessageBox.No) == QtGui.QMessageBox.Yes:
            os.system('gedit ' + meshDict_path)

class MyModel:
    @staticmethod
    def sumOfThreeEdgesOfCadObjects(freecad_objects):
        xmin = ymin = zmin = float('inf')
        xmax = ymax = zmax = float('-inf')
        for obj in freecad_objects:
            try:
                if obj.ViewObject.Visibility and obj.Shape is not None:
                    xmin = min(xmin, obj.Shape.BoundBox.XMin)
                    ymin = min(ymin, obj.Shape.BoundBox.YMin)
                    zmin = min(zmin, obj.Shape.BoundBox.ZMin)
                    xmax = max(xmax, obj.Shape.BoundBox.XMax)
                    ymax = max(ymax, obj.Shape.BoundBox.YMax)
                    zmax = max(zmax, obj.Shape.BoundBox.ZMax)
            except:
                pass
        return xmax - xmin + ymax - ymin + zmax - zmin

    @staticmethod
    def exportStl(freecad_objects, grid, file_name):
        fd, tmp_stl = tempfile.mkstemp(suffix = '.ast')
        os.close(fd)
        os.remove(tmp_stl)
        xmin = ymin = zmin = float('inf')
        xmax = ymax = zmax = float('-inf')
        with open(file_name, 'w') as f:
            for i in grid.table:
                if i[grid.TYPE] in ('BoxRefine', 'CylinderRefine', 'SphereRefine',
                    'BoxSet', 'CylinderSet', 'SphereSet', 'BoxTopo', 'CylinderTopo', 'SphereTopo',
                    'LocationInMesh', 'N/A'):
                    continue
                for obj in freecad_objects:
                    if i[grid.OBJECT_NAME] == obj.Label:
                        if i[grid.TYPE] == 'SurfaceRefine':
                            name = os.path.join(os.path.dirname(file_name), i[grid.OBJECT_NAME])
                            Mesh.export([obj], f'{name}.ast') # ascii format
                            os.rename(f'{name}.ast', f'{name}.stl') # can overwrite
                        else:
                            Mesh.export([obj], tmp_stl)
                            # ascii stlフォーマット
                            # solid 任意の文字列
                            # facet normal x成分値 y成分値 z成分値
                            # outer loop
                            # vertex x成分値 y成分値 z成分値
                            # vertex x成分値 y成分値 z成分値
                            # vertex x成分値 y成分値 z成分値
                            # endloop
                            # endfacet
                            #（facet normal行～endfacet行までを１枚の三角形データとして以降くり返し）
                            # ..............
                            # endsolid 任意の文字列
                            for line in open(tmp_stl, 'r'):
                                if 'endsolid' in line:
                                    f.write(f'endsolid {i[grid.OBJECT_NAME]}\n')
                                elif 'solid' in line:
                                    f.write(f'solid {i[grid.OBJECT_NAME]}\n')
                                else:
                                    f.write(line)
                                    if line.lstrip().startswith('vertex'):
                                        x, y, z = [float(j) for j in line.split()[1:]]
                                        xmin, ymin, zmin = min(xmin, x), min(ymin, y), min(zmin, z)
                                        xmax, ymax, zmax = max(xmax, x), max(ymax, y), max(zmax, z)
                            os.remove(tmp_stl)
                        break
        return xmin, ymin, zmin, xmax, ymax, zmax

    @staticmethod
    def makeSurfaceFeatureExtractDict(case_dir_path, surface_file_name, feature_angle):
        dict_name = os.path.join(case_dir_path, 'system', 'surfaceFeatureExtractDict')
        with open(dict_name, 'w') as f:
            f.write('FoamFile\n'
                '{\n'
                '\tversion\t2.0;\n'
                '\tformat\tascii;\n'
                '\tclass\tdictionary;\n'
                '\tlocation\t"system";\n'
                '\tobject\tsurfaceFeatureExtractDict;\n'
                '}\n'
                '\n'
                f'{os.path.basename(surface_file_name)}\n'
                '{\n'
                '\textractionMethod\textractFromSurface;\n'
                '\n'
                '\t// Mark edges whose adjacent surface normals are at an angle less\n'
                '\t// than includedAngle as features\n'
                '\t// - 0  : selects no edges\n'
                '\t// - 180: selects all edges\n'
                f'\tincludedAngle\t{180.0 - float(feature_angle)};\n'
                '\n'
                '\t// Write options\n'
                '\twriteFeatureEdgeMesh\tyes;\n'
                '\n'
                '\t// Write features to obj format for postprocessing\n'
                '\twriteObj\tyes;\n'
                '}\n')
        os.chmod(dict_name, 0o0666)

    @staticmethod
    def makeMeshDict(case_dir_path, surface_file_name, max_cell_size, bounding_box,
        freecad_objects, grid, features_level, feature_angle, meshDict):
        dict_name = os.path.join(case_dir_path, 'system', 'snappyHexMeshDict')
        if os.path.isfile(dict_name):
            shutil.copy(dict_name, dict_name + '_bak')
        with open(dict_name, 'w') as f:
            f.write('FoamFile\n'
                '{\n'
                '\tversion\t2.0;\n'
                '\tformat\tascii;\n'
                '\tclass\tdictionary;\n'
                '\tlocation\t"system";\n'
                '\tobject\tsnappyHexMeshDict;\n'
                '}\n'
                '\n'
                '// A manual is available on\n'
                '// https://www.openfoam.com/documentation/guides/latest/doc/guide-meshing-snappyhexmesh.html\n'
                '\n'
                '// Which of the steps to run\n')
            for i in ('castellatedMesh', 'snap', 'addLayers'):
                run = meshDict.find_element([{'type': 'dictionary', 'key': i}, {'type': 'word'}])['element']
                if run is None:
                    f.write(f'{i}\ttrue; // true or false\n')
                else:
                    f.write(f'{i}\t{run["value"]}; // true or false\n')

            f.write('\n'
                'CUSTOM_OPTIONS\n'
                '{\n'
                f'\tmaxCellSize\t{max_cell_size}; // used to generate blockMeshDict\n'
                f'\tboundingBox\t(({bounding_box[0]} {bounding_box[1]} {bounding_box[2]}) '
                f'({bounding_box[3]} {bounding_box[4]} {bounding_box[5]})); '
                '// used to generate blockMeshDict\n'
                '}\n')

            objects = [i[grid.OBJECT_NAME] for i in grid.table]
            surface_file_name = os.path.basename(surface_file_name)
            surface_file_name_wo_ext = os.path.splitext(surface_file_name)[0]
            f.write('\n'
                '// Geometry. Definition of all surfaces.\n'
                '// All surfaces are of class searchableSurface.\n'
                '// Surfaces are used\n'
                '// - to specify refinement for any mesh cell intersecting it\n'
                '// - to specify refinement for any mesh cell inside/outside/near\n'
                "// - to 'snap' the mesh boundary to the surface\n"
                'geometry\n'
                '{\n'
                f'\t{surface_file_name} // in constant/triSurface\n'
                '\t{\n'
                '\t\ttype\ttriSurfaceMesh;\n'
                f'\t\tname\t{surface_file_name_wo_ext};\n'
                '\t}\n')
            for i in grid.table:
                if i[grid.LEVEL] == 0:
                    continue
                if i[grid.TYPE] in ('BoxRefine', 'CylinderRefine', 'SphereRefine'):
                    for obj in freecad_objects:
                        if i[grid.OBJECT_NAME] == obj.Label:
                            f.write('\n'
                                f'\t{i[grid.OBJECT_NAME]}\n'
                                '\t{\n')
                            if i[grid.TYPE] == 'BoxRefine':
                                f.write('\t\ttype\tsearchableRotatedBox;\n'
                                    f'\t\tspan\t({obj.Length.Value} {obj.Width.Value} {obj.Height.Value});\n'
                                    f'\t\torigin\t({obj.Placement.Base.x} {obj.Placement.Base.y} '
                                    f'{obj.Placement.Base.z});\n'
                                    f'\t\te1\t({obj.Placement.Matrix.A11} {obj.Placement.Matrix.A21} '
                                    f'{obj.Placement.Matrix.A31});\n'
                                    f'\t\te3\t({obj.Placement.Matrix.A13} {obj.Placement.Matrix.A23} '
                                    f'{obj.Placement.Matrix.A33});\n')
                            elif i[grid.TYPE] == 'CylinderRefine':
                                f.write('\t\ttype\tsearchableCylinder;\n'
                                    f'\t\tpoint1\t({obj.Placement.Base.x} {obj.Placement.Base.y} '
                                    f'{obj.Placement.Base.z});\n'
                                    '\t\tpoint2\t'
                                    f'({obj.Placement.Base.x + obj.Placement.Matrix.A13*obj.Height.Value} '
                                    f'{obj.Placement.Base.y + obj.Placement.Matrix.A23*obj.Height.Value} '
                                    f'{obj.Placement.Base.z + obj.Placement.Matrix.A33*obj.Height.Value});\n'
                                    f'\t\tradius\t{obj.Radius.Value};\n')
                            elif i[grid.TYPE] == 'SphereRefine':
                                f.write('\t\ttype\tsearchableSphere;\n'
                                    f'\t\tcentre\t({obj.Placement.Base.x} {obj.Placement.Base.y} '
                                    f'{obj.Placement.Base.z});\n'
                                    f'\t\tradius\t{obj.Radius.Value};\n')
                            f.write('\t}\n')
                            break
                elif i[grid.TYPE] == 'SurfaceRefine':
                    f.write(f'\n'
                        '\t{i[grid.OBJECT_NAME]}.stl // in constant/triSurface\n'
                        '\t{\n'
                        '\t\ttype\ttriSurfaceMesh;\n'
                        f'\t\tname\t{i[grid.OBJECT_NAME]};\n'
                        '\t}\n')
            for block in meshDict.find_all_elements([{'type': 'block', 'key': 'geometry'},
                {'type': 'block'}]):
                block = block['element']
                if block['key'] != surface_file_name and block['key'] not in objects:
                    f.write('\n'
                        f'\t{dictParse.file_string([block], indent_level = 1, pretty_print = True)}\n')
            f.write('\n'
                '//\tboxExample\n'
                '//\t{\n'
                '//\t\ttype\tsearchableBox;\n'
                '//\t\tmin\t(1.5 1 -0.5);\n'
                '//\t\tmax\t(3.5 2 0.5);\n'
                '//\t}\n'
                '\n'
                '//\trotatedBoxExample\n'
                '//\t{\n'
                '//\t\ttype\tsearchableRotatedBox;\n'
                '//\t\tspan\t(5 4 3); // in (e1 e2 e3) directions\n'
                '//\t\torigin\t(0 0 0);\n'
                '//\t\te1\t(1 0.5 0);\n'
                '//\t\te3\t(0 0.5 1);\n'
                '//\t}\n'
                '\n'
                '//\tconeExample\n'
                '//\t{\n'
                '//\t\ttype\tsearchableCone;\n'
                '//\t\tpoint1\t(0 0 0);\n'
                '//\t\tradius1\t1.5;\n'
                '//\t\tinnerRadius1\t0.25;\n'
                '//\t\tpoint2\t(10 0 0);\n'
                '//\t\tradius2\t3.0;\n'
                '//\t\tinnerRadius2\t1.0;\n'
                '//\t}\n'
                '\n'
                '//\tcylinderExample\n'
                '//\t{\n'
                '//\t\ttype\tsearchableCylinder;\n'
                '//\t\tpoint1\t(1.5 1 -0.5);\n'
                '//\t\tpoint2\t(3.5 2 0.5);\n'
                '//\t\tradius\t0.05;\n'
                '//\t}\n'
                '\n'
                '//\tdiskExample\n'
                '//\t{\n'
                '//\t\ttype\tsearchableDisk;\n'
                '//\t\torigin\t(0 0 0);\n'
                '//\t\tnormal\t(0 1 0);\n'
                '//\t\tradius\t0.314;\n'
                '//\t}\n'
                '\n'
                '//\tsphereExample\n'
                '//\t{\n'
                '//\t\ttype\tsearchableSphere;\n'
                '//\t\tcentre\t(0 0 0);\n'
                '//\t\tradius\t3;\n'
                '//\t}\n'
                '}\n') # geometry

            castellatedMeshControls = meshDict.find_element(
                [{'type': 'block', 'key': 'castellatedMeshControls'}])['element']
            f.write('\n'
                '// Settings for the castellatedMesh generation.\n'
                'castellatedMeshControls\n'
                '{\n'
                '\t// ----- Refinement parameters -----\n'
                '\n'
                '\t// Maximum number of cells per processor during refinement\n')
            maxLocalCells = dictParse.find_element(
                [{'type': 'dictionary', 'key': 'maxLocalCells'}, {'type': 'integer'}],
                parent = castellatedMeshControls)['element']
            if maxLocalCells is None:
                f.write('\tmaxLocalCells\t100000;\n')
            else:
                f.write(f'\tmaxLocalCells\t{maxLocalCells["value"]};\n')
            f.write('\n'
                '\t// Overall cell limit during refinement (i.e. before removal)\n')
            maxGlobalCells = dictParse.find_element(
                [{'type': 'dictionary', 'key': 'maxGlobalCells'}, {'type': 'integer'}],
                parent = castellatedMeshControls)['element']
            if maxGlobalCells is None:
                f.write('\tmaxGlobalCells\t2000000;\n')
            else:
                f.write(f'\tmaxGlobalCells\t{maxLocalCells["value"]};\n'
                '\n'
                '\t// The refinement along the surfaces may spend many iterations on refinement\n'
                '\t// of only few cells. Whenever the number of cells to be refined is less than\n'
                '\t// or equal to the minRefinementCells parameter, the refinement will stop.\n'
                '\t// be performed.\n')
            minRefinementCells = dictParse.find_element(
                [{'type': 'dictionary', 'key': 'minRefinementCells'}, {'type': 'integer'}],
                parent = castellatedMeshControls)['element']
            if minRefinementCells is None:
                f.write('\tminRefinementCells\t2;\n')
            else:
                f.write(f'\tminRefinementCells\t{minRefinementCells["value"]};\n')
            f.write('\n'
                '\t// Number of buffer layers of cells between different levels of refinement\n')
            nCellsBetweenLevels = dictParse.find_element(
                [{'type': 'dictionary', 'key': 'nCellsBetweenLevels'}, {'type': 'integer'}],
                parent = castellatedMeshControls)['element']
            if nCellsBetweenLevels is None:
                f.write('\tnCellsBetweenLevels\t3;\n')
            else:
                f.write(f'\tnCellsBetweenLevels\t{nCellsBetweenLevels["value"]};\n')
            f.write('\n'
                '\t// ----- Explicit feature edge refinement -----\n'
                '\n'
                '\t// Specifies a level for any cell intersected by its edges.\n'
                '\tfeatures\n'
                '\t(\n'
                '\t\t{\n'
                '\t\t\tfile\t"' + surface_file_name_wo_ext + '.extendedFeatureEdgeMesh";\n'
                '\t\t\tlevel\t' + features_level + ';\n'
                '\t\t}\n'
                '\t);\n'
                '\n'
                '\t// ----- Surface based refinement -----\n'
                '\n'
                '\trefinementSurfaces\n'
                '\t{\n'
                f'\t\t{surface_file_name_wo_ext}\n'
                '\t\t{\n');
            f.write('\t\t\tlevel\t(0 1); // (min max)\n'
                '\t\t\tregions\n'
                '\t\t\t{\n');
            for i in grid.table:
                if i[grid.TYPE] in (
                    'BoxRefine', 'CylinderRefine', 'SphereRefine', 'SurfaceRefine',
                    'BoxSet', 'CylinderSet', 'SphereSet', 'BoxTopo', 'CylinderTopo', 'SphereTopo',
                    'LocationInMesh', 'N/A'):
                    continue
                f.write(f'\t\t\t\t{i[grid.OBJECT_NAME]}\n'
                    '\t\t\t\t{\n'
                    f'\t\t\t\t\tlevel\t({i[grid.LEVEL]} {i[grid.LEVEL] + 1}); // (min max)\n'
                    '\t\t\t\t\tpatchInfo\t{' f'type\t{i[grid.TYPE]};' '}\n'
                    '\t\t\t\t}\n'
                    '\t\t\t}\n'
                    '\t\t}\n'
                    '\t}\n' # refinementSurfaces
                    '\n'
                    f'\tresolveFeatureAngle\t{feature_angle};\n'
                    '\n'
                    '\t// ----- Region-wise refinement -----\n'
                    '\n'
                    '\trefinementRegions\n'
                    '\t{\n'
                    '\t\t//                    ********************\n'
                    '\t\t//                    ********************   ******************\n'
                    '\t\t// +--------------+   **+--------------+**   *+--------------+*\n'
                    '\t\t// |**************|   **|              |**   *|**************|*\n'
                    '\t\t// |**************|   **|              |**   *|*            *|*\n'
                    '\t\t// |*** inside ***|   **|   outside    |**   *|*  distance ->|*<-\n'
                    '\t\t// |**************|   **|              |**   *|*          ->*|<-\n'
                    '\t\t// |**************|   **|              |**   *|**************|*\n'
                    '\t\t// +--------------+   **+--------------+**   *+--------------+*\n'
                    '\t\t//                    ********************   ******************\n'
                    '\t\t//                    ********************\n')
            for i in grid.table:
                if i[grid.LEVEL] == 0 or i[grid.TYPE] not in ('BoxRefine', 'CylinderRefine',
                    'SphereRefine', 'SurfaceRefine'):
                    continue
                f.write('\n'
                    f'\t\t{i[grid.OBJECT_NAME]}\n'
                    '\t\t{\n')
                if i[grid.TYPE] in ('BoxRefine', 'CylinderRefine', 'SphereRefine'):
                    f.write('\t\t\tmode\tinside; // distance | inside | outside\n'
                        f'\t\t\tlevels\t((1.0 {i[grid.LEVEL]}));'
                        ' // ((distance level)), distance is used only in a distance mode.\n')
                else: # SurfaceRefine
                    f.write('\t\t\tmode\tdistance;\n'
                        '\t\t\tlevels\t(({i[grid.RATIO]} {i[grid.LEVEL]}));'
                        ' // ((distance1 level1) (distance2 level2) ...), '
                        'distance1 < distance2, level1 > level2\n')
                f.write('\t\t}\n')
            for block in dictParse.find_all_elements([{'type': 'block', 'key': 'refinementRegions'},
                {'type': 'block'}], parent = castellatedMeshControls):
                block = block['element']
                if block['key'] != surface_file_name and block['key'] not in objects:
                    f.write('\n'
                        f'\t\t{dictParse.file_string([block], indent_level = 2, pretty_print = True)}\n')
            f.write('\t}\n') # refinementRegions

            f.write('\n'
                '\t// ----- Mesh selection -----\n')
            cellZone = []
            for i in grid.table:
                if i[grid.TYPE] == 'LocationInMesh':
                    for obj in freecad_objects:
                        if i[grid.OBJECT_NAME] == obj.Label:
                            cellZone.append((obj.Shape.CenterOfMass.x, obj.Shape.CenterOfMass.y,
                                             obj.Shape.CenterOfMass.z, i[grid.OBJECT_NAME]))
                            break
            if len(cellZone) == 1:
                f.write('\n'
                    f'\tlocationInMesh\t({cellZone[0][0]} {cellZone[0][1]} {cellZone[0][2]});\n'
                    '\n'
                    '//\tlocationsInMesh\n'
                    '//\t(\n'
                    '//\t\t((0.0 0.0 0.0) zone1)\n'
                    '//\t\t((0.1 0.1 0.1) zone2)\n'
                    '//\t);\n')
            else:
                f.write('\n'
                    '//\tlocationInMesh\t(0.0 0.0 0.0)\n'
                    '\n'
                    '\tlocationsInMesh\n'
                    '\t(\n')
                for i in cellZone:
                    f.write(f'\t\t(({i[0]} {i[1]} {i[2]}) {i[3]})\n')
                f.write('\t);\n'
                    '\n'
                    '\t// Whether any faceZones (as specified in the refinementSurfaces)\n'
                    '\t// are only on the boundary of corresponding cellZones or also allow\n'
                    '\t// free-standing zone faces. Not used if there are no faceZones.\n'
                    '\n'
                    '\t// allowFreeStandingZoneFaces allowing zone faces that share the same\n'
                    '\t// owner and neighbour cell zone. Not used if there are no faceZones.\n')
            allowFreeStandingZoneFaces = dictParse.find_element(
                [{'type': 'dictionary', 'key': 'allowFreeStandingZoneFaces'}, {'type': 'word'}],
                parent = castellatedMeshControls)['element']
            if allowFreeStandingZoneFaces is None:
                f.write('\tallowFreeStandingZoneFaces\ttrue;\n')
            else:
                f.write(f'\tallowFreeStandingZoneFaces\t{allowFreeStandingZoneFaces["value"]};\n')
            for element in dictParse.find_all_elements([{'type': 'block|dictionary',
                'except key': ('maxLocalCells' '|' 'maxGlobalCells' '|' 'minRefinementCells' '|'
                    'nCellsBetweenLevels' '|' 'features' '|' 'refinementSurfaces' '|'
                    'resolveFeatureAngle' '|' 'refinementRegions' '|' 'locationInMesh' '|'
                    'locationsInMesh' '|' 'allowFreeStandingZoneFaces')}],
                    parent = castellatedMeshControls):
                 f.write('\n'
                    f'\t{dictParse.file_string([element["element"]], indent_level = 1, pretty_print = True)}\n')
            f.write('}\n') # castellatedMeshControls

            snapControls = meshDict.find_element([{'type': 'block', 'key': 'snapControls'}])['element']
            f.write('\n'
                '// Settings for the snapping.\n'
                'snapControls\n'
                '{\n'
                '\t// Number of smoothing iterations along the surface\n')
            nSmoothPatch = dictParse.find_element([{'type': 'dictionary', 'key': 'nSmoothPatch'},
                {'type': 'integer'}], parent = snapControls)['element']
            if nSmoothPatch is None:
                f.write('\tnSmoothPatch\t3;\n')
            else:
                f.write(f'\tnSmoothPatch\t{nSmoothPatch["value"]};\n')
            f.write('\n'
                '\t// Number of iterations for internal smoothing to reduce non-orthogonality\n'
                '\t// at the face of refinement (effectively making the faces non-planar).\n'
                '\t// Default value is 0.\n')
            nSmoothInternal = dictParse.find_element([{'type': 'dictionary', 'key': 'nSmoothInternal'},
                {'type': 'integer'}], parent = snapControls)['element']
            if nSmoothInternal is None:
                f.write('\tnSmoothInternal\t1;\n')
            else:
                f.write(f'\tnSmoothInternal\t{nSmoothInternal["value"]};\n')
            f.write('\n'
                '\t// Multiplied by local cell-edge length specifies region along the surface\n'
                '\t// within which the points are attracted by the surface\n')
            tolerance = dictParse.find_element([{'type': 'dictionary', 'key': 'tolerance'},
                {'type': 'float|integer'}], parent = snapControls)['element']
            if tolerance is None:
                f.write('\ttolerance\t1.0;\n')
            else:
                f.write(f'\ttolerance\t{tolerance["value"]};\n')
            f.write('\n'
                '\t// Number of mesh displacement iterations\n')
            nSolveIter = dictParse.find_element([{'type': 'dictionary', 'key': 'nSolveIter'},
                {'type': 'integer'}], parent = snapControls)['element']
            if nSolveIter is None:
                f.write('\tnSolveIter\t30;\n')
            else:
                f.write(f'\tnSolveIter\t{nSolveIter["value"]};\n')
            f.write('\n'
                '\t// Number of relaxation iterations during the snapping. If the mesh does not\n'
                '\t// conform the geometry and all the iterations are spend, user may try to\n'
                '\t// increase the number of iterations.\n')
            nRelaxIter = dictParse.find_element([{'type': 'dictionary', 'key': 'nRelaxIter'},
                {'type': 'integer'}], parent = snapControls)['element']
            if nRelaxIter is None:
                f.write('\tnRelaxIter\t5;\n')
            else:
                f.write(f'\tnRelaxIter\t{nRelaxIter["value"]};\n')
            f.write('\n'
                '\t// Number of relaxation iterations used for snapping onto the features.\n'
                '\t// If not specified, feature snapping will be disabled.\n')
            nFeatureSnapIter = dictParse.find_element([{'type': 'dictionary', 'key': 'nFeatureSnapIter'},
                {'type': 'integer'}], parent = snapControls)['element']
            if nFeatureSnapIter is None:
                f.write('\tnFeatureSnapIter\t10;\n')
            else:
                f.write(f'\tnFeatureSnapIter\t{nFeatureSnapIter["value"]};\n')
            for element in dictParse.find_all_elements([{'type': 'block|dictionary',
                'except key': ('nSmoothPatch' '|' 'nSmoothInternal' '|' 'tolerance' '|'
                    'nSolveIter' '|' 'nRelaxIter' '|' 'nFeatureSnapIter')}],
                    parent = snapControls):
                 f.write('\n'
                    f'\t{dictParse.file_string([element["element"]], indent_level = 1, pretty_print = True)}\n')
            f.write('}\n') # snapControls

            addLayersControls = meshDict.find_element(
                [{'type': 'block', 'key': 'addLayersControls'}])['element']
            f.write('\n'
                '// Settings for the layer addition.\n'
                'addLayersControls\n'
                '{\n'
                '\t// Layer thickness is set in a relative (true) or absolute (false) scale.\n'
                '\trelativeSizes\ttrue;\n'
                '\n'
                '\t// Layer information per final patch (so not geometry!)\n'
                '\tlayers\n'
                '\t{\n')
            for i in grid.table:
                if not i[grid.BOUNDARY_LAYER] or i[grid.TYPE] in (
                    'BoxRefine', 'CylinderRefine', 'SphereRefine', 'SurfaceRefine',
                    'BoxSet', 'CylinderSet', 'SphereSet', 'BoxTopo', 'CylinderTopo', 'SphereTopo',
                    'LocationInMesh', 'N/A'):
                    continue
                f.write(f'\t\t{surface_file_name_wo_ext}_{i[grid.OBJECT_NAME]}\n'
                    '\t\t{\n'
                    f'\t\t\tnSurfaceLayers\t{i[grid.N_LAYERS]};\n'
                    f'\t\t\texpansionRatio\t{i[grid.RATIO]};\n')
                for element in dictParse.find_all_elements([{'type': 'block', 'key': 'layers'},
                    {'type': 'block', 'key': f'{surface_file_name_wo_ext}_{i[grid.OBJECT_NAME]}'},
                    {'type': 'block|dictionary', 'except key': 'nSurfaceLayers|expansionRatio'}],
                    parent = addLayersControls):
                    f.write(f'\t\t\t{dictParse.file_string([element["element"]], indent_level = 3, pretty_print = True)}\n')
                f.write('\t\t}\n')
            f.write('\t}\n') # layers
            expansionRatio = dictParse.find_element([{'type': 'dictionary', 'key': 'expansionRatio'},
                {'type': 'float|integer'}], parent = addLayersControls)['element']
            if expansionRatio is None:
                f.write('\texpansionRatio\t1; // mandatory\n')
            else:
                f.write(f'\texpansionRatio\t{expansionRatio["value"]}; // mandatory\n')
            f.write('\n'
                '\t// Thickness of the layer furthest away from the wall\n')
            finalLayerThickness = dictParse.find_element([{'type': 'dictionary', 'key': 'finalLayerThickness'},
                {'type': 'float|integer'}], parent = finalLayerThickness)['element']
            if finalLayerThickness is None:
                f.write('\tfinalLayerThickness\t1;\n')
            else:
                f.write(f'\tfinalLayerThickness\t{finalLayerThickness["value"]};\n')
            f.write('\n'
                '\t// Minimum thickness of cell layer\n')
            minThickness = dictParse.find_element([{'type': 'dictionary', 'key': 'minThickness'},
                {'type': 'float|integer'}], parent = addLayersControls)['element']
            if minThickness is None:
                f.write('\tminThickness\t0.1;\n')
            else:
                f.write(f'\tminThickness\t{minThickness["value"]};\n')
            f.write('\n'
                '\t// Number of layers of cells where point extrusion is cancelled\n')
            nGrow = dictParse.find_element([{'type': 'dictionary', 'key': 'nGrow'},
                {'type': 'integer'}], parent = addLayersControls)['element']
            if nGrow is None:
                f.write('\tnGrow\t0;\n')
            else:
                f.write(f'\tnGrow\t{nGrow["value"]};\n')
            f.write('\n'
                '\t// ----- Advanced settings -----\n'
                '\n'
                '\t// When not to extrude surface. 0 is flat surface, 90 is when two faces\n'
                '\t// are perpendicular\n'
                f'\tfeatureAngle\t{feature_angle};\n'
                '\n'
                '\t// Number of relaxation steps (where relaxed mesh quality parameters are used)\n')
            nRelaxIter = dictParse.find_element([{'type': 'dictionary', 'key': 'nRelaxIter'},
                {'type': 'integer'}], parent = addLayersControls)['element']
            if nRelaxIter is None:
                f.write('\tnRelaxIter\t3;\n')
            else:
                f.write(f'\tnRelaxIter\t{nRelaxIter["value"]};\n')
            f.write('\n'
                '\t// Number of smoothing iterations of surface normals\n')
            nSmoothSurfaceNormals = dictParse.find_element([{'type': 'dictionary', 'key': 'nSmoothSurfaceNormals'},
                {'type': 'integer'}], parent = addLayersControls)['element']
            if nSmoothSurfaceNormals is None:
                f.write('\tnSmoothSurfaceNormals\t1;\n')
            else:
                f.write(f'\tnSmoothSurfaceNormals\t{nSmoothSurfaceNormals["value"]};\n')
            f.write('\n'
                '\t// Number of smoothing iterations of interior mesh movement direction\n')
            nSmoothNormals = dictParse.find_element([{'type': 'dictionary', 'key': 'nSmoothNormals'},
                {'type': 'integer'}], parent = addLayersControls)['element']
            if nSmoothNormals is None:
                f.write('\tnSmoothNormals\t3;\n')
            else:
                f.write(f'\tnSmoothNormals\t{nSmoothNormals["value"]};\n')
            f.write('\n'
                '\t// Smooth layer thickness over surface patches\n')
            nSmoothThickness = dictParse.find_element([{'type': 'dictionary', 'key': 'nSmoothThickness'},
                {'type': 'integer'}], parent = addLayersControls)['element']
            if nSmoothThickness is None:
                f.write('\tnSmoothThickness\t10;\n')
            else:
                f.write(f'\tnSmoothThickness\t{nSmoothThickness["value"]};\n')
            f.write('\n'
                '\t// Stop layer growth on highly warped cells\n')
            maxFaceThicknessRatio = dictParse.find_element([{'type': 'dictionary', 'key': 'maxFaceThicknessRatio'},
                {'type': 'float|integer'}], parent = addLayersControls)['element']
            if maxFaceThicknessRatio is None:
                f.write('\tmaxFaceThicknessRatio\t0.5;\n')
            else:
                f.write(f'\tmaxFaceThicknessRatio\t{maxFaceThicknessRatio["value"]};\n')
            f.write('\n'
                '\t// Reduce layer growth where ratio thickness to medial distance is large\n')
            maxThicknessToMedialRatio = dictParse.find_element(
                [{'type': 'dictionary', 'key': 'maxThicknessToMedialRatio'},
                {'type': 'float|integer'}], parent = addLayersControls)['element']
            if maxThicknessToMedialRatio is None:
                f.write('\tmaxThicknessToMedialRatio\t1;\n')
            else:
                f.write(f'\tmaxThicknessToMedialRatio\t{maxThicknessToMedialRatio["value"]};\n')
            f.write('\n'
                '\t// Angle used to select medial axis points\n')
            minMedialAxisAngle = dictParse.find_element([{'type': 'dictionary', 'key': 'minMedialAxisAngle'},
                {'type': 'float|integer'}], parent = addLayersControls)['element']
            if minMedialAxisAngle is None:
                f.write('\tminMedialAxisAngle\t90;\n')
            else:
                f.write(f'\tminMedialAxisAngle\t{minMedialAxisAngle["value"]};\n')

            f.write('\n'
                '\t// Create buffer region for new layer terminations\n')
            nBufferCellsNoExtrude = dictParse.find_element(
                [{'type': 'dictionary', 'key': 'nBufferCellsNoExtrude'},
                {'type': 'float|integer'}], parent = addLayersControls)['element']
            if nBufferCellsNoExtrude is None:
                f.write('\tnBufferCellsNoExtrude\t0;\n')
            else:
                f.write(f'\tnBufferCellsNoExtrude\t{nBufferCellsNoExtrude["value"]};\n')
            f.write('\n'
                '\t// Overall max number of layer addition iterations\n')
            nLayerIter = dictParse.find_element([{'type': 'dictionary', 'key': 'nLayerIter'},
                {'type': 'integer'}], parent = addLayersControls)['element']
            if nLayerIter is None:
                f.write('\tnLayerIter\t50;\n')
            else:
                f.write(f'\tnLayerIter\t{nLayerIter["value"]};\n')
            f.write('\n'
                ''
                '\t// Max number of iterations after which relaxed meshQuality controls\n'
                '\t// get used. Up to nRelaxIter it uses the settings in meshQualityControls,\n'
                '\t// after nRelaxIter it uses the values in meshQualityControls::relaxed.\n')
            nRelaxedIter = dictParse.find_element([{'type': 'dictionary', 'key': 'nRelaxedIter'},
                {'type': 'integer'}], parent = addLayersControls)['element']
            if nRelaxedIter is None:
                f.write('\tnRelaxedIter\t50;\n')
            else:
                f.write(f'\tnRelaxedIter\t{nRelaxedIter["value"]};\n')
            for element in dictParse.find_all_elements([{'type': 'block|dictionary',
                'except key': ('relativeSizes' '|' 'layers' '|' 'expansionRatio' '|'
                    'finalLayerThickness' '|' 'minThickness' '|' 'nGrow' '|' 'featureAngle' '|'
                    'nRelaxIter' '|' 'nSmoothSurfaceNormals' '|' 'nSmoothNormals' '|'
                    'nSmoothThickness' '|' 'maxFaceThicknessRatio' '|' 'maxThicknessToMedialRatio' '|'
                    'minMedialAxisAngle' '|' 'nBufferCellsNoExtrude' '|' 
                    'nLayerIter' '|' 'nRelaxedIter')}],
                    parent = addLayersControls):
                 f.write('\n'
                    f'\t{dictParse.file_string([element["element"]], indent_level = 1, pretty_print = True)}\n')
            f.write('}\n') # addLayersControls

            meshQualityControls = meshDict.find_element(
                [{'type': 'block', 'key': 'meshQualityControls'}])['element']
            f.write('\n'
                '// Generic mesh quality settings. At any undoable phase these determine\n'
                '// where to undo.\n'
                'meshQualityControls\n'
                '{\n'
                '\t#includeEtc "caseDicts/meshQualityDict"\n'
                '\n'
                '\t// Optional: some meshing phases allow usage of relaxed rules.\n'
                '\t// See e.g. addLayersControls.nRelaxedIter.\n'
                '\trelaxed\n'
                '\t{\n'
                '\t\t// Maximum non-orthogonality allowed. Set to 180 to disable.\n')
            relaxed = dictParse.find_element([{'type': 'block', 'key': 'relaxed'}],
                parent = meshQualityControls)['element']
            maxNonOrtho = dictParse.find_element([{'type': 'dictionary', 'key': 'maxNonOrtho'},
                {'type': 'float|integer'}], parent = relaxed)['element']
            if maxNonOrtho is None:
                f.write('\tmaxNonOrtho\t75;\n')
            else:
                f.write(f'\tmaxNonOrtho\t{maxNonOrtho["value"]};\n')
            for element in dictParse.find_all_elements(
                [{'type': 'block|dictionary', 'except key': 'maxNonOrtho'}], parent = relaxed):
                 f.write('\n'
                    f'\t\t{dictParse.file_string([element["element"]], indent_level = 2, pretty_print = True)}\n')
            f.write('\t}\n' # relaxed
                '\n'
                '\t// ----- Advanced -----\n'
                '\n'
                '\t// Smoothing iterations. Used in combination with errorReduction.\n')
            nSmoothScale = dictParse.find_element([{'type': 'dictionary', 'key': 'nSmoothScale'},
                {'type': 'integer'}], parent = meshQualityControls)['element']
            if nSmoothScale is None:
                f.write('\tnSmoothScale\t4;\n')
            else:
                f.write(f'\tnSmoothScale\t{nSmoothScale["value"]};\n')
            f.write('\n'
                '\t// Error reduction. Used in combination with nSmoothScale.\n')
            errorReduction = dictParse.find_element([{'type': 'dictionary', 'key': 'errorReduction'},
                {'type': 'float|integer'}], parent = meshQualityControls)['element']
            if errorReduction is None:
                f.write('\terrorReduction\t0.75;\n')
            else:
                f.write(f'\terrorReduction\t{errorReduction["value"]};\n')
            for element in dictParse.find_all_elements([{'type': 'block|dictionary',
                'except key': 'nSmoothScale|relaxed|errorReduction'}],
                    parent = meshQualityControls):
                 f.write('\n'
                    f'\t{dictParse.file_string([element["element"]], indent_level = 1, pretty_print = True)}\n')
            f.write('}\n') # meshQualityControls

            f.write('\n'
                '// ----- Advanced -----\n'
                '\n'
                '// Merge tolerance. Is fraction of overall bounding box of initial mesh.\n'
                '// Note: the write tolerance needs to be higher than this.\n')
            mergeTolerance = meshDict.find_element([{'type': 'block', 'key': 'mergeTolerance'},
                {'type': 'float|integer'}])['element']
            if mergeTolerance is None:
                f.write('\tmergeTolerance\t1.0e-06;\n')
            else:
                f.write(f'\tmergeTolerance\t{mergeTolerance["value"]};\n')

            for element in meshDict.find_all_elements([{'type': 'block|dictionary',
                'except key': ('FoamFile' '|' 'CUSTOM_OPTIONS' '|' 'castellatedMesh' '|' 'snap' '|'
                    'addLayers' '|' 'geometry' '|' 'castellatedMeshControls' '|' 'snapControls' '|'
                    'addLayersControls' '|' 'meshQualityControls' '|' 'mergeTolerance')}]):
                 f.write('\n'
                    f'{dictParse.file_string([element["element"]], pretty_print = True)}\n')

        os.chmod(dict_name, 0o0666)

    @staticmethod
    def makeSetFieldsDict(case_dir_path, freecad_objects, grid, setFieldsDict):
        has_set = False
        for i in grid.table:
            if i[grid.TYPE] in ('BoxSet', 'CylinderSet', 'SphereSet'):
                has_set = True
                break
        if not has_set:
            return
        dict_name = os.path.join(case_dir_path, 'system', 'setFieldsDict')
        if os.path.isfile(dict_name):
            shutil.copy(dict_name, dict_name + '_bak')

        with open(dict_name, 'w') as f:
            f.write('FoamFile\n'
                '{\n'
                '\tversion\t2.0;\n'
                '\tformat\tascii;\n'
                '\tclass\tdictionary;\n'
                '\tlocation\t"system";\n'
                '\tobject\tsetFieldsDict;\n'
                '}\n'
                '\n')

            defaultFieldValues = setFieldsDict.find_element(
                [{'type': 'dictionary', 'key': 'defaultFieldValues'}])['element']
            if defaultFieldValues is not None:
                f.write(f'{dictParse.file_string([defaultFieldValues], pretty_print = True)}\n')
            else:
                f.write('defaultFieldValues // regionsで指定しない領域における値\n'
                    '(\n'
                    '\tvolScalarFieldValue\talpha.water 0 // ←自分の目的に合わせて書き換える\n'
                    '\tvolVectorFieldValue\tU ( 0 0 0 ) // ←自分の目的に合わせて書き換える\n'
                    ');\n')

            regions = setFieldsDict.find_element([{'type': 'dictionary', 'key': 'regions'},
                {'type': 'list'}])['element']
            f.write('\n'
                'regions\n'
                '(\n')
            for i in grid.table:
                if i[grid.TYPE] not in ('BoxSet', 'CylinderSet', 'SphereSet'):
                    continue
                for obj in freecad_objects:
                    if i[grid.OBJECT_NAME] == obj.Label:
                        if i[grid.TYPE] == 'BoxSet':
                            f.write(f'\tboxToCell // Object {i[grid.OBJECT_NAME]} in FreeCAD\n'
                                '\t{\n'
                                f'\t\tbox\t({0.001*obj.Shape.BoundBox.XMin} '
                                f'{0.001*obj.Shape.BoundBox.YMin} {0.001*obj.Shape.BoundBox.ZMin}) '
                                f'({0.001*obj.Shape.BoundBox.XMax} {0.001*obj.Shape.BoundBox.YMax} '
                                f'{0.001*obj.Shape.BoundBox.ZMax});\n')
                        elif i[grid.TYPE] == 'CylinderSet':
                            f.write(f'\tcylinderToCell // Object {i[grid.OBJECT_NAME]} in FreeCAD\n'
                                '\t{\n'
                                '\t\tp1\t'
                                f'({0.001*obj.Placement.Base.x} {0.001*obj.Placement.Base.y} '
                                f'{0.001*obj.Placement.Base.z});\n')
                            f.write('\t\tp2\t'
                                f'({0.001*(obj.Placement.Base.x + obj.Placement.Matrix.A13*obj.Height.Value)} '
                                f'{0.001*(obj.Placement.Base.y + obj.Placement.Matrix.A23*obj.Height.Value)} '
                                f'{0.001*(obj.Placement.Base.z + obj.Placement.Matrix.A33*obj.Height.Value)});\n')
                            f.write(f'\t\tradius\t{0.001*obj.Radius.Value};\n')
                        else: # SphereSet
                            f.write(f'\tsphereToCell // Object {i[grid.OBJECT_NAME]} in FreeCAD\n'
                                '\t{\n'
                                f'\t\tcentre\t({0.001*obj.Placement.Base.x} '
                                f'{0.001*obj.Placement.Base.y} {0.001*obj.Placement.Base.z});\n'
                                f'\t\tradius\t{0.001*obj.Radius.Value};\n')
                        break
                for comment in dictParse.find_all_elements(
                    [{'type': 'block'}, {'type': 'line_comment|block_comment'}], parent = regions):
                    block = block['element']
                    if i[grid.OBJECT_NAME] not in comment['element']['value']:
                        continue
                    fieldValues = dictParse.find_element([{'type': 'dictionary', 'key': 'fieldValues'}],
                        parent = comment['parent'])['element']
                    if fieldValues is None:
                        f.write('\t\tfieldValues\n'
                        '\t\t(\n'
                        '\t\t\tvolScalarFieldValue alpha.water 1 // ←自分の目的に合わせて書き換える\n'
                        '\t\t);\n')
                    else:
                        f'\t\t{dictParse.file_string([dictionary["element"]], indent_level = 2, pretty_print = True)}\n'
                f.write('\t}\n') # boxToCell, cylinderToCell, sphereToCell
            for block in dictParse.find_all_elements([{'type': 'block'}], parent = regions):
                block = block['element']
                comment = dictParse.find_element([{'type': 'line_comment|block_comment'}],
                    parent = block)['element']['value']
                if 'freecad' not in comment.lower():
                    f.write('\n'
                        f'\t{dictParse.file_string([block], indent_level = 1, pretty_print = True)}\n')
                f.write(');\n') # regions

            for element in setFieldsDict.find_all_elements([{'type': 'block|dictionary',
                'except key': 'FoamFile|defaultFieldValues|regions'}]):
                f.write('\n'
                    f'{dictParse.file_string([element["element"]], pretty_print = True)}\n')

        os.chmod(dict_name, 0o0666)

    @staticmethod
    def makeTopoSetDict(case_dir_path, freecad_objects, grid, topoSetDict):
        has_topo = False
        for i in grid.table:
            if i[grid.TYPE] == 'BoxTopo':
                has_topo = True
                break
        if not has_topo:
            return
        dict_name = os.path.join(case_dir_path, 'system', 'topoSetDict')
        if os.path.isfile(dict_name):
            shutil.copy(dict_name, dict_name + '_bak')

        with open(dict_name, 'w') as f:
            f.write('FoamFile\n'
                '{\n'
                '\tversion\t2.0;\n'
                '\tformat\tascii;\n'
                '\tclass\tdictionary;\n'
                '\tlocation\t"system";\n'
                '\tobject\ttopoSetDict;\n'
                '}\n') # FoamFile

            actions = topoSetDict.find_all_element([{'type': 'dictionary', 'key': 'actions'},
                {'type': 'list'}, {'type': 'block'}])
            f.write('\n'
                'actions\n'
                '(\n')
            for i in grid.table:
                if i[grid.TYPE] not in ('BoxTopo', 'CylinderTopo', 'SphereTopo'):
                    continue
                block = next((i['element'] for i in actions if dictParse.find_element(
                    [{'type': 'dictionary', 'key': 'name'},
                    {'type': 'word', 'value': f'{i[grid.OBJECT_NAME]}CellSet'}],
                    parent = i['element'])['element'] is not None), None)
                if block is None:
                    action = 'new'
                else:
                    action = dictParse.find_element([{'type': 'dictionary', 'key': 'action'},
                        {'type': 'word'}], parent = block)['element']
                    if action is None:
                        action = 'new'
                f.write('\t{' f' // Object {i[grid.OBJECT_NAME]} in FreeCAD\n'
                    f'\t\tname\t{i[grid.OBJECT_NAME]}CellSet;\n'
                    '\t\ttype\tcellSet;\n'
                    f'\t\taction\t{action};\t// new | add | subtract\n')
                for obj in freecad_objects:
                    if i[grid.OBJECT_NAME] == obj.Label:
                        if i[grid.TYPE] == 'BoxTopo':
                            f.write('\t\tsource\trotatedBoxToCell;\n'
                                f'\t\torigin\t({0.001*obj.Placement.Base.x} '
                                f'{0.001*obj.Placement.Base.y} {0.001*obj.Placement.Base.z});\n'
                                f'\t\ti\t({0.001*obj.Length.Value*obj.Placement.Matrix.A11} '
                                f'{0.001*obj.Length.Value*obj.Placement.Matrix.A21} '
                                f'{0.001*obj.Length.Value*obj.Placement.Matrix.A31});\n'
                                f'\t\tj\t({0.001*obj.Width.Value*obj.Placement.Matrix.A12} '
                                f'{0.001*obj.Width.Value*obj.Placement.Matrix.A22} '
                                f'{0.001*obj.Width.Value*obj.Placement.Matrix.A32});\n'
                                f'\t\tk\t({0.001*obj.Height.Value*obj.Placement.Matrix.A13} '
                                f'{0.001*obj.Height.Value*obj.Placement.Matrix.A23} '
                                f'{0.001*obj.Height.Value*obj.Placement.Matrix.A33});\n')
                        elif i[grid.TYPE] == 'CylinderTopo':
                            f.write('\t\tsource\tcylinderToCell;\n'
                                f'\t\tp1\t({0.001*obj.Placement.Base.x} '
                                f'{0.001*obj.Placement.Base.y} {0.001*obj.Placement.Base.z});\n'
                                '\t\tp2\t'
                                f'({0.001*(obj.Placement.Base.x + obj.Placement.Matrix.A13*obj.Height.Value)} '
                                f'{0.001*(obj.Placement.Base.y + obj.Placement.Matrix.A23*obj.Height.Value)} '
                                f'{0.001*(obj.Placement.Base.z + obj.Placement.Matrix.A33*obj.Height.Value)});\n'
                                f'\t\tradius\t{0.001*obj.Radius.Value};\n')
                        else: # SphereTopo
                            f.write('\t\tsource\tsphereToCell;\n'
                                f'\t\torigin\t({0.001*obj.Placement.Base.x} '
                                f'{0.001*obj.Placement.Base.y} {0.001*obj.Placement.Base.z});\n'
                                '\t\tradius\t{0.001*obj.Radius.Value};\n')
                        f.write('\t}\n')
                        break
            for i in grid.table:
                if i[grid.TYPE] in ('BoxTopo', 'CylinderTopo', 'SphereTopo'):
                    f.write('\t{' f' // Object {i[grid.OBJECT_NAME]} in FreeCAD\n'
                        f'\t\tname\t{i[grid.OBJECT_NAME]};\n'
                        '\t\ttype\tcellZoneSet;\n'
                        '\t\taction\tnew;\n'
                        '\t\tsource\tsetToCellZone;\n'
                        f'\t\tset\t{i[grid.OBJECT_NAME]}CellSet;\n'
                        '\t}\n')
            written_action_names = '|'.join(
                [f'{i[grid.OBJECT_NAME]}|{i[grid.OBJECT_NAME]}CellSet' for i in grid.table])
            for block in actions:
                block = ['element']
                if dictParse.find_element( [{'type': 'dictionary', 'key': 'name'},
                    {'type': 'word', 'except value': written_action_names}],
                    parent = block)['element'] is not None:
                    f.write('\n'
                        f'\t{dictParse.file_string([block], indent_level = 1, pretty_print = True)}\n')
            f.write(');\n') # actions

            for element in topoSetDict.find_all_elements([{'type': 'block|dictionary',
                'except key': 'FoamFile|actions'}]):
                f.write('\n'
                    f'{dictParse.file_string([element["element"]], pretty_print = True)}\n')

        os.chmod(dict_name, 0o0666)

if __name__ == '__main__':
    MyController()
