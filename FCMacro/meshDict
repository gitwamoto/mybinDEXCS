FoamFile
{
	version	2.0;
	format	ascii;
	class	dictionary;
	location	"system";
	object	meshDict;
}

// A manual is available on
// http://cfmesh.com/wp-content/uploads/2015/09/User_Guide-cfMesh_v1.1.pdf

CUSTOM_OPTIONS
{
	featureAngle	30; // used in surfaceFeatureEdges utility
}

// Keep all the cells intersecting the surface template.
// Useful in capturing small gaps in a geometry. (default: 0)
keepCellsIntersectingBoundary	1; // 1 active or 0 inactive

// Remove cells where distinct parts of the mesh are joined together.
// Valid only when keepCellsIntersectingBoundary is active. (default: 0)
checkForGluedMesh	0; // 1 active or 0 inactive

maxCellSize	1.2; // (mandatory)

// boundaryCellSize	0.5; // (optional)
// boundaryCellSizeRefinementThickness	5.0; // (optional)

// minCellSize	1; // (optional)

surfaceFile	"constant/triSurface/package001.fms"; // (mandatory)

boundaryLayers
{
	// Smoothing of boundary layers (default: 0)
	optimiseLayer	1; // 1 active or 0 inactive

	optimisationParameters
	{
		// Ratio between the maximum boundary layer thickness and the patch size
		// Ued to limit layer thickness in the regions dominated by curvature. (default: 0.3)
		featureSizeFactor	0.3;

		// Maximum difference of the layer thickness between two neighboring points
		// divided by the distance between the points (optional)
		relThicknessTol	0.2;
	}

	patchBoundaryLayers
	{
		"Wall[0-9]*"
		{
			nLayers	2; // (optional)
			thicknessRatio	1.2;
//			maxFirstLayerThickness	0.5; // (optional)
			allowDiscontinuity	0; // 1 active or 0 inactive
		}
	}
}

// Valid only when keepCellsIntersectingBoundary is not active. (optional)
keepCellsIntersectingPatches
{
//	"patch.*" // accepts regex
//	{
//		keepCells	1; // 1 active or 0 inactive
//	}
}

// Valid only when keepCellsIntersectingBoundary is active. (optional)
removeCellsIntersectingPatches
{
//	"patch.*" // accepts regex
//	{
//		keepCells	0; // 0 remove or 1 keep
//	}
}

localRefinement
